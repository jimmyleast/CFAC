# UHP — Staging Environment Variables
# Copy this file to .env.staging-new (or .env.<environment-slug>) and fill in all values.
# Run: node scripts/setup-railway-env.mjs --environment "Staging - New"
#
# DO NOT commit the filled-in file. Only this .example is committed.

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Supabase (shared test project — same for all 3 services) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ydhrlgxwmvumbggpdydd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Per-service app URLs (Railway-generated for this environment) ─────────────
# OPS-Agent: maps to NEXT_PUBLIC_APP_URL + NEXT_PUBLIC_SITE_URL on the ops service
NEXT_PUBLIC_APP_URL_OPS=
NEXT_PUBLIC_SITE_URL_OPS=
# field-execution: maps to NEXT_PUBLIC_APP_URL on the field service
NEXT_PUBLIC_APP_URL_FIELD=
# student-app: maps to NEXT_PUBLIC_APP_URL + NEXT_PUBLIC_SITE_URL on the student service
NEXT_PUBLIC_APP_URL_STUDENT=
NEXT_PUBLIC_SITE_URL_STUDENT=

# ── Cross-service URLs (set on OPS-Agent) ─────────────────────────────────────
NEXT_PUBLIC_STUDENT_APP_URL=
NEXT_PUBLIC_FIELD_EXEC_URL=

# ── Cross-service URLs (set on field + student) ───────────────────────────────
UHP_OPS_AGENT_URL=

# ── Push Notifications (VAPID — generate once per project, reuse across envs) ─
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Cron & Auth ───────────────────────────────────────────────────────────────
CRON_SECRET=
ALLOWED_EMAIL_DOMAINS=uhp.com
ADMIN_EMAIL=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_FROM_NUMBER=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_OPS=
SLACK_CHANNEL_ISSUES=
SLACK_CHANNEL_URGENT=
SLACK_CHANNEL_TECH=

# ── HubSpot (CRM) ─────────────────────────────────────────────────────────────
HUBSPOT_PRIVATE_APP_TOKEN=

# ── HeyGen (AI Video — optional on staging) ───────────────────────────────────
HEYGEN_API_KEY=
NEXT_PUBLIC_HEYGEN_AVATAR_ID=Anna_public_3_20240108
NEXT_PUBLIC_HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8
NEXT_PUBLIC_HEYGEN_AVATAR_POOL=Anna_public_3_20240108
NEXT_PUBLIC_HEYGEN_VOICE_POOL=1bd001e7e50f421d891986aad5158bc8

# ── Operative / Forge (optional — all features degrade gracefully if blank) ───
OPERATIVE_CORE_URL=
OPERATIVE_CORE_KEY=
OPERATIVE_COMMS_URL=
OPERATIVE_COMMS_KEY=
OPERATIVE_OPS_URL=
OPERATIVE_OPS_KEY=
OPERATIVE_DEPLOYMENT_ID=uhp-morgan

# ── Student-app specific ──────────────────────────────────────────────────────
# Set to "true" to enforce active-student check on the student app
UHP_ENFORCE_ACTIVE_STUDENT=false
