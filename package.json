    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "docx": "^9.6.1",
    "googleapis": "^171.4.0",
    "jsonrepair": "^3.13.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
