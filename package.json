{
  "name": "cfac",
  "version": "1.0.0",
  "description": "CFAC operations & data platform",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test smoke.spec.ts",
    "test:e2e:contracts": "playwright test contracts.spec.ts",
    "test:e2e:auth": "playwright test authenticated.spec.ts",
    "test:e2e:perf": "playwright test performance.spec.ts",
    "test:e2e:validation": "playwright test validation.spec.ts",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:desktop": "playwright test --project=chromium",
    "verify:strict": "npm run lint && npm run build && playwright test --repeat-each=3",
    "verify:comprehensive": "npm run lint && npm run build && npm run test:e2e:smoke && npm run test:e2e:contracts && npm run test:e2e:auth && npm run test:e2e:perf && npm run test:e2e:validation",
    "verify:ci": "npm run lint && npm run build && playwright test --reporter=json,html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmyleast/UHP-OPS-Agent.git"
  },
