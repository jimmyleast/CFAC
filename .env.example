# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# VaultIQ inventory bridge (server-only)
MORGAN_VAULTIQ_API_KEY=your_vaultiq_morgan_key
VAULTIQ_BASE_URL=https://vaultiqai-production.up.railway.app
# Optional once VaultIQ exposes receipt/BOL/invoice parsing
VAULTIQ_DOCUMENT_ENDPOINT=/api/morgan/inventory-document

# HeyGen
HEYGEN_API_KEY=your_heygen_api_key
NEXT_PUBLIC_HEYGEN_AVATAR_ID=Anna_public_3_20240108
NEXT_PUBLIC_HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8
# Optional comma-separated pools for deterministic squad-based randomization
NEXT_PUBLIC_HEYGEN_AVATAR_POOL=Anna_public_3_20240108
NEXT_PUBLIC_HEYGEN_VOICE_POOL=1bd001e7e50f421d891986aad5158bc8

# Resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Auth
ALLOWED_EMAIL_DOMAINS=yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Operative / Forge (all optional — features degrade gracefully)
OPERATIVE_CORE_URL=
OPERATIVE_CORE_KEY=
OPERATIVE_BUILDER_URL=
OPERATIVE_BUILDER_API_KEY=
OPERATIVE_COMMS_URL=
OPERATIVE_COMMS_KEY=
OPERATIVE_PUBLISH_URL=
OPERATIVE_PUBLISH_KEY=
OPERATIVE_OPS_URL=
OPERATIVE_OPS_KEY=
OPERATIVE_MODELS_URL=
OPERATIVE_MODELS_KEY=
OPERATIVE_DEPLOYMENT_ID=uhp-morgan
CLIPFORGE_API_URL=
CLIPFORGE_API_KEY=

# Discovery bridge (optional)
DISCOVERY_VIDEO_TEMPLATE_URL=

# Slack (optional — used for ops notifications)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_OPS=

# Twilio (optional — SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Backward-compatible alias currently used in notification sender
TWILIO_FROM_NUMBER=
