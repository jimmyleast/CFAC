# CFAC — environment variables. Copy to .env.local and fill in.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# For running migrations locally (Project Settings → Database):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres

# AI providers (Hope assistant: Anthropic primary; OpenAI + Gemini for cross-model critique)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Email (Resend) — transactional auth/invite emails
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@cfacbentonco.com

# Auth
ALLOWED_EMAIL_DOMAINS=cfacbentonco.com
ADMIN_EMAIL=admin@cfacbentonco.com
